{
  "manifest_version": 3,
  "name": "Darija Translator Side Panel",
  "description": "Translate selected text to Moroccan Darija using the secured backend service.",
  "version": "1.0.0",
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Darija Translator"
  }
}
